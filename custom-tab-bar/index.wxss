.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 112rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #fffdf8;
  border-top: 1rpx solid #ebe3d5;
  box-shadow: 0 -10rpx 32rpx rgba(36, 48, 43, 0.06);
  box-sizing: content-box;
}

.tab-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 156rpx;
  height: 72rpx;
  color: #68736b;
  border-radius: 8rpx;
}

.tab-item.active {
  color: #1f6f54;
  background: #e8f2ea;
  font-weight: 700;
}

.tab-dot {
  width: 10rpx;
  height: 10rpx;
  margin-bottom: 8rpx;
  background: transparent;
  border-radius: 50%;
}

.tab-item.active .tab-dot {
  background: #1f6f54;
}

.tab-text {
  font-size: 24rpx;
  line-height: 1;
}
