name = "motiontrace-api"
main = "src/worker.js"
compatibility_date = "2026-06-22"

[[routes]]
pattern = "motiontrace.631581.xyz"
custom_domain = true

[[d1_databases]]
binding = "DB"
database_name = "motiontrace"
database_id = "replace-with-your-d1-database-id"

[vars]
APP_NAME = "motiontrace"
# 管理后台默认账号：admin，默认密码：Admin@1357。
# 如需覆盖，可在 Cloudflare Worker 变量中设置 ADMIN_USERNAME / ADMIN_PASSWORD。
