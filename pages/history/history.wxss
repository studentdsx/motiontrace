.history-page {
  padding: 28rpx 24rpx 190rpx;
  box-sizing: border-box;
}

.history-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.eyebrow {
  color: #728071;
  font-size: 24rpx;
}

.title {
  margin-top: 6rpx;
  color: #18231f;
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.count-pill {
  min-width: 88rpx;
  padding: 10rpx 18rpx;
  color: #1f6f54;
  font-size: 24rpx;
  text-align: center;
  background: #e8f2ea;
  border-radius: 999rpx;
}

.day-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.day-card {
  padding: 24rpx;
  background: #fffdf8;
  border: 1rpx solid #ebe3d5;
  border-radius: 8rpx;
}

.day-main {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: center;
}

.day-date {
  color: #1e2925;
  font-size: 34rpx;
  font-weight: 700;
}

.day-week {
  margin-top: 8rpx;
  color: #778178;
  font-size: 24rpx;
}

.arrow {
  color: #9a8f80;
  font-size: 46rpx;
  line-height: 1;
}

.summary-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee6d9;
}

.summary-value,
.summary-label {
  display: block;
}

.summary-value {
  color: #25302b;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.25;
  word-break: break-all;
}

.summary-label {
  margin-top: 6rpx;
  color: #7b847c;
  font-size: 22rpx;
}

.history-empty {
  margin-top: 80rpx;
}
