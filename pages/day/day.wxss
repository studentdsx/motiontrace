.day-page {
  padding: 28rpx 24rpx 190rpx;
  box-sizing: border-box;
}

.detail-head {
  margin-bottom: 20rpx;
}

.eyebrow {
  color: #728071;
  font-size: 24rpx;
}

.title {
  margin-top: 6rpx;
  color: #18231f;
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.detail-map {
  width: 100%;
  height: 620rpx;
  border: 1rpx solid #e5ddcf;
  border-radius: 8rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-top: 18rpx;
}

.stat-item {
  min-width: 0;
  padding: 20rpx 10rpx 18rpx;
  text-align: center;
  background: #fffdf8;
  border: 1rpx solid #ece3d5;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.stat-value {
  display: block;
  color: #1d2a25;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.2;
  word-break: break-all;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  color: #7c857c;
  font-size: 22rpx;
}

.section-head {
  margin: 38rpx 0 18rpx;
  color: #1e2925;
  font-size: 32rpx;
  font-weight: 700;
}

.timeline {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.timeline-item {
  display: grid;
  grid-template-columns: 96rpx 1fr;
  gap: 16rpx;
}

.time {
  padding-top: 22rpx;
  color: #d7654b;
  font-size: 24rpx;
  font-weight: 700;
}

.timeline-body {
  padding: 22rpx;
  background: #fffdf8;
  border: 1rpx solid #ebe3d5;
  border-radius: 8rpx;
}

.note {
  color: #26312d;
  font-size: 28rpx;
  line-height: 1.5;
}

.photo-strip {
  width: 100%;
  margin-top: 16rpx;
  white-space: nowrap;
}

.thumb {
  width: 150rpx;
  height: 150rpx;
  margin-right: 12rpx;
  background: #efe8dc;
  border-radius: 8rpx;
}
