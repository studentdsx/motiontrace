<view class="page day-page">
  <view class="detail-head">
    <view>
      <view class="eyebrow">{{weekLabel}}</view>
      <view class="title">{{date}}</view>
    </view>
  </view>

  <map
    class="detail-map"
    latitude="{{center.latitude}}"
    longitude="{{center.longitude}}"
    scale="{{scale}}"
    polyline="{{polyline}}"
    markers="{{markers}}"
  ></map>

  <view class="stats-grid">
    <view class="stat-item">
      <text class="stat-value">{{stats.distance}}</text>
      <text class="stat-label">距离</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.duration}}</text>
      <text class="stat-label">时长</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.points}}</text>
      <text class="stat-label">轨迹点</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.checkins}}</text>
      <text class="stat-label">打卡</text>
    </view>
  </view>

  <view class="section-head">打卡时间线</view>
  <view wx:if="{{checkins.length}}" class="timeline">
    <view wx:for="{{checkins}}" wx:key="id" class="timeline-item">
      <view class="time">{{item.time}}</view>
      <view class="timeline-body">
        <view class="note">{{item.note || '没有文字备注'}}</view>
        <scroll-view wx:if="{{item.photos.length}}" class="photo-strip" scroll-x>
          <image
            wx:for="{{item.photos}}"
            wx:for-item="photo"
            wx:key="*this"
            class="thumb"
            src="{{photo}}"
            mode="aspectFill"
            data-photos="{{item.photos}}"
            data-src="{{photo}}"
            bindtap="previewPhoto"
          />
        </scroll-view>
      </view>
    </view>
  </view>
  <view wx:else class="empty">这一天只有路线，还没有照片打卡。</view>
</view>
