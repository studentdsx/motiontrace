.index-page {
  padding: 24rpx 24rpx 190rpx;
  box-sizing: border-box;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.eyebrow {
  color: #728071;
  font-size: 24rpx;
}

.title {
  margin-top: 6rpx;
  color: #18231f;
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.record-toggle {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 216rpx;
  padding: 16rpx 16rpx 16rpx 20rpx;
  color: #6d766f;
  font-size: 24rpx;
  background: #fffdf8;
  border: 1rpx solid #e9e0d1;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.record-toggle.active {
  color: #1f6f54;
  border-color: #b8d7c3;
  box-shadow: 0 12rpx 32rpx rgba(31, 111, 84, 0.12);
}

.track-map {
  width: 100%;
  height: 640rpx;
  overflow: hidden;
  border: 1rpx solid #e5ddcf;
  border-radius: 8rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-top: 18rpx;
}

.stat-item {
  min-width: 0;
  padding: 20rpx 10rpx 18rpx;
  text-align: center;
  background: #fffdf8;
  border: 1rpx solid #ece3d5;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.stat-value {
  display: block;
  color: #1d2a25;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.2;
  word-break: break-all;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  color: #7c857c;
  font-size: 22rpx;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 14rpx;
  margin-top: 20rpx;
}

.secondary-btn,
.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.secondary-btn {
  color: #27342f;
  background: #fffdf8;
  border: 1rpx solid #e6ddce;
}

.primary-btn {
  color: #fffdf8;
  background: #d7654b;
  box-shadow: 0 14rpx 30rpx rgba(215, 101, 75, 0.2);
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin: 36rpx 0 16rpx;
  color: #1e2925;
  font-size: 32rpx;
  font-weight: 700;
}

.section-head .muted {
  font-size: 24rpx;
  font-weight: 400;
}

.checkin-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.checkin-card {
  padding: 22rpx;
  background: #fffdf8;
  border: 1rpx solid #ebe3d5;
  border-radius: 8rpx;
}

.checkin-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #667267;
  font-size: 24rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  background: #d7654b;
  border-radius: 50%;
}

.checkin-note {
  margin-top: 12rpx;
  color: #26312d;
  font-size: 28rpx;
  line-height: 1.5;
}

.photo-strip {
  width: 100%;
  margin-top: 16rpx;
  white-space: nowrap;
}

.thumb {
  width: 132rpx;
  height: 132rpx;
  margin-right: 12rpx;
  background: #efe8dc;
  border-radius: 8rpx;
}

.thumb.large {
  width: 160rpx;
  height: 160rpx;
}

.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 1200;
  display: flex;
  align-items: flex-end;
  background: rgba(24, 35, 31, 0.34);
}

.checkin-sheet {
  display: flex;
  flex-direction: column;
  width: 100%;
  max-height: 82vh;
  padding: 28rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  background: #fffdf8;
  border-radius: 8rpx 8rpx 0 0;
  box-sizing: border-box;
}

.sheet-head {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: center;
}

.sheet-title {
  color: #1d2824;
  font-size: 34rpx;
  font-weight: 700;
}

.sheet-sub {
  margin-top: 8rpx;
  color: #7a8279;
  font-size: 22rpx;
}

.sheet-head-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.text-btn {
  width: 82rpx;
  height: 64rpx;
  color: #6b766e;
  font-size: 26rpx;
  background: transparent;
}

.head-save-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 108rpx;
  height: 64rpx;
  color: #fffdf8;
  font-size: 26rpx;
  font-weight: 700;
  background: #d7654b;
  border-radius: 8rpx;
}

.head-save-btn[disabled] {
  color: rgba(255, 253, 248, 0.72);
  background: #d9a095;
}

.sheet-body {
  flex: 1;
  min-height: 0;
  max-height: 58vh;
  margin-top: 22rpx;
}

.field-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #26312d;
  font-size: 26rpx;
  font-weight: 700;
}

.field-label .muted {
  color: #8b928b;
  font-size: 22rpx;
  font-weight: 400;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 14rpx;
}

.photo-cell {
  position: relative;
  aspect-ratio: 1;
  min-width: 0;
}

.sheet-thumb,
.add-photo {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.sheet-thumb {
  display: block;
  background: #efe8dc;
}

.remove-photo {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  color: #fffdf8;
  font-size: 34rpx;
  line-height: 1;
  background: #26312d;
  border-radius: 50%;
}

.add-photo {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  aspect-ratio: 1;
  color: #667267;
  font-size: 24rpx;
  background: #f7f4ee;
  border: 1rpx dashed #d7ccbc;
  box-sizing: border-box;
}

.add-mark {
  color: #d7654b;
  font-size: 46rpx;
  font-weight: 300;
  line-height: 1;
}

.note-label {
  margin-top: 24rpx;
}

.note-input {
  width: 100%;
  height: 150rpx;
  margin-top: 14rpx;
  padding: 20rpx;
  color: #1f2925;
  font-size: 28rpx;
  line-height: 1.45;
  background: #f7f4ee;
  border: 1rpx solid #ebe2d4;
  border-radius: 8rpx;
  box-sizing: border-box;
}
