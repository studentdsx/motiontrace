<view class="page index-page">
  <view class="topbar">
    <view>
      <view class="eyebrow">{{weekLabel}}</view>
      <view class="title">{{dateLabel}}</view>
    </view>
    <view class="record-toggle {{isRecording ? 'active' : ''}}">
      <text>{{isRecording ? '记录中' : '未记录'}}</text>
      <switch checked="{{isRecording}}" color="#1f6f54" bindchange="onRecordSwitch" />
    </view>
  </view>

  <map
    id="trackMap"
    class="track-map"
    latitude="{{center.latitude}}"
    longitude="{{center.longitude}}"
    scale="{{scale}}"
    polyline="{{polyline}}"
    markers="{{markers}}"
    show-location
  ></map>

  <view class="stats-grid">
    <view class="stat-item">
      <text class="stat-value">{{stats.distance}}</text>
      <text class="stat-label">距离</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.duration}}</text>
      <text class="stat-label">时长</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.points}}</text>
      <text class="stat-label">轨迹点</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.checkins}}</text>
      <text class="stat-label">打卡</text>
    </view>
  </view>

  <view class="action-row">
    <button class="secondary-btn" bindtap="centerOnMe">定位</button>
    <button class="primary-btn" bindtap="startCheckin">打卡</button>
  </view>

  <view class="section-head">
    <text>今日打卡</text>
    <text class="muted">{{checkins.length}} 个地点</text>
  </view>

  <view wx:if="{{checkins.length}}" class="checkin-list">
    <view wx:for="{{checkins}}" wx:key="id" class="checkin-card">
      <view class="checkin-meta">
        <text class="dot"></text>
        <text>{{item.time}}</text>
      </view>
      <view class="checkin-note">{{item.note || '没有文字备注'}}</view>
      <scroll-view wx:if="{{item.photos.length}}" class="photo-strip" scroll-x>
        <image
          wx:for="{{item.photos}}"
          wx:for-item="photo"
          wx:key="*this"
          class="thumb"
          src="{{photo}}"
          mode="aspectFill"
          data-photos="{{item.photos}}"
          data-src="{{photo}}"
          bindtap="previewPhoto"
        />
      </scroll-view>
    </view>
  </view>
  <view wx:else class="empty">今天还没有打卡，路线上的某个瞬间可以从这里留下。</view>

  <view wx:if="{{checkinSheet}}" class="sheet-mask" catchtap="cancelCheckin">
    <view class="checkin-sheet" catchtap="noop">
      <view class="sheet-head">
        <view>
          <view class="sheet-title">保存打卡</view>
          <view class="sheet-sub">{{pendingLocationText}}</view>
        </view>
        <view class="sheet-head-actions">
          <button class="text-btn" bindtap="cancelCheckin">取消</button>
          <button
            class="head-save-btn"
            loading="{{savingCheckin}}"
            disabled="{{savingCheckin}}"
            bindtap="confirmCheckin"
          >保存</button>
        </view>
      </view>

      <scroll-view class="sheet-body" scroll-y>
        <view class="field-label">
          <text>照片</text>
          <text class="muted">{{selectedPhotos.length}}/{{maxPhotos}}</text>
        </view>
        <view class="photo-grid">
          <view wx:for="{{selectedPhotos}}" wx:key="*this" class="photo-cell">
            <image
              class="sheet-thumb"
              src="{{item}}"
              mode="aspectFill"
              data-photos="{{selectedPhotos}}"
              data-src="{{item}}"
              bindtap="previewPhoto"
            />
            <button
              class="remove-photo"
              data-index="{{index}}"
              catchtap="removeSelectedPhoto"
            >×</button>
          </view>
          <button
            wx:if="{{selectedPhotos.length < maxPhotos}}"
            class="add-photo"
            bindtap="chooseCheckinPhotos"
          >
            <text class="add-mark">+</text>
            <text>添加照片</text>
          </button>
        </view>

        <view class="field-label note-label">备注</view>
        <textarea
          class="note-input"
          value="{{note}}"
          maxlength="80"
          placeholder="写一句此刻的备注"
          adjust-position="{{true}}"
          show-confirm-bar="{{false}}"
          bindinput="onNoteInput"
        />
      </scroll-view>

    </view>
  </view>
</view>
