page {
  min-height: 100%;
  color: #24302b;
  background: #f7f4ee;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

button {
  padding: 0;
  margin: 0;
  line-height: 1;
  border-radius: 8rpx;
  font: inherit;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #f7f4ee;
}

.muted {
  color: #778178;
}

.empty {
  padding: 56rpx 32rpx;
  color: #778178;
  text-align: center;
  background: #fffdf8;
  border: 1rpx solid #ebe4d6;
  border-radius: 8rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 18rpx;
  color: #1f6f54;
  font-size: 22rpx;
  background: #e8f2ea;
  border-radius: 999rpx;
}
